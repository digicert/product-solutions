        <http_method>POST</http_method>
        <name>Resend Renew Email</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {

	var data = request.body.data;
  
    if (!data.certificateSysId) {
      response.setStatus(400);
      return;
    }
  
    try {
      var certificateRenewService = new CertificateRenewService();
      certificateRenewService.resenRenewalEmail(data.certificateSysId,data.adminComment );
  
      response.setStatus(204);
    } catch (error) {
      response.setStatus(500);
      response.setBody({
        error: error.message,
      });
    }

})(request, response);]]></operation_script>
