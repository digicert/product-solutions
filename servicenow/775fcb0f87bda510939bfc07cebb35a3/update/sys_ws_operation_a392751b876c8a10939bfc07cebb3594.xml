        <http_method>GET</http_method>
        <name>Migration status</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
	var logger = new Logger('CertificatesMigrationStatus');
	var httpRequestUtils = new HttpRequestUtils();

    try {
		var accountId = request.pathParams.accountId;
		var status = httpRequestUtils.get(Constants.URL.getCertificatesMigrationStatus.replace('{accountId}', accountId));
		status = JSON.parse(status);

		response.setStatus(200);
		response.setBody(status);
	} catch(error) {
		logger.error("Failed to fetch migration status for account: {0}, Error: {1}", accountId, error);
		response.setStatus(500);
		response.setBody({
			error: error.message,
		});
	}

})(request, response);]]></operation_script>
