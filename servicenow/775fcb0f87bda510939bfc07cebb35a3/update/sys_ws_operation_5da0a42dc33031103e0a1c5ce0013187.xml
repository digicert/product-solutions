        <name>Set current environment</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
  var data = request.body.data;

  if (!data.baseApiUrl) {
    response.setStatus(400);
    response.setBody({
      error: 'baseApiUrl property has not been provided',
    });
    return;
  }

  try {
    var service = new ApplicationPropertyService();
    service.setBaseApiUrl(data.baseApiUrl);
    response.setStatus(204);
  } catch (error) {
    response.setStatus(error.message.includes('not valid') ? 400 : 500);
    response.setBody({
      error: error.message,
    });
  }
})(request, response);
]]></operation_script>
