        <name>Get</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
    var logger = new Logger('Application Property Get');
	var service = new ApplicationPropertyService();

    try {
		var propName = request.pathParams.propName;
		var value = service.get(propName);

		var result = {};
		result[propName] = value;

		response.setStatus(200);
		response.setBody(result);
	} catch(error) {
		logger.error("Failed to get application property: {0}, Error: {1}", propName, error);
		response.setStatus(500);
		response.setBody({
			error: error.message,
		});
	}
})(request, response);]]></operation_script>
