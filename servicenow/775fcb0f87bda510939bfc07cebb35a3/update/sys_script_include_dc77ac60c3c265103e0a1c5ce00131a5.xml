        <script><![CDATA[var UrlProcessorService = Class.create();
UrlProcessorService.prototype = {
  initialize: function () {},
  /**
   * Replace parts or url within {} with params Object fields
   *
   * @param {String} url
   * @param {Object} params Object with url params.
   * @return {String}
   */
  replaceUrlParams: function (url, params) {
    return url.replace(/{(.*?)}/g, function (m, g1) {
      return params[g1] || m;
    });
  },

  type: 'UrlProcessorService',
};
]]></script>
