        <http_method>GET</http_method>
        <name>Get all environments</name>
        <operation_script><![CDATA[(function process(/*RESTAPIRequest*/ request, /*RESTAPIResponse*/ response) {
  try {
    var service = new ApplicationPropertyService();
    var environments = service.getEnvironmentUrls();
  } catch (error) {
    response.setStatus(500);
    response.setBody({
      error:
        "Can't get the list of environments. Check the " + Constants.APP_SCOPE + '.environments system property value',
    });
    return;
  }

  environments.currentEnvUrl = gs.getProperty(Constants.APP_SCOPE + '.base_api_url');

  response.setStatus(200);
  response.setBody(environments);
})(request, response);
]]></operation_script>
